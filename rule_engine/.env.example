# ============================================
# Capline Rule Engine & RCM - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# ---- Spring Profile ----
SPRING_PROFILES_ACTIVE=prod

# ---- Database Configuration (shared by Rule Engine & RCM) ----
DB_URL=jdbc:mysql://your-rds-endpoint:3306/rule_engine?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ---- JWT Configuration ----
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=600000

# ---- Rule Engine Application ----
APPLICATION_URL=https://your-domain.com
RE_ADMIN=admin_admin

# ---- RMC/RCM Auth Token (used for inter-service communication) ----
RMC_AUTH_TOKEN=your-rcm-auth-token

# ---- EagleSoft SSL Configuration ----
# For dev/testing: set ES_SSL_CLIENT_TRUSTALL=true (no certs needed)
# For production:  set ES_SSL_CLIENT_TRUSTALL=false and provide certs in ./certs/
ES_SSL_CLIENT_PASSWORD=changeit
ES_SSL_CLIENT_TRUSTSTORE=/opt/project/tricon/client/cacerts.jks
ES_SSL_CLIENT_KEYSTORE=/opt/project/tricon/client/keystore.jks
ES_SSL_CLIENT_TRUSTALL=false

# ---- Google Configuration ----
GOOGLE_CREDENTIAL_FOLDER=/opt/project/tricon/files
GOOGLE_CLIENT_SECRET_FILE=/opt/project/tricon/files/client_secret.json
GOOGLE_CHROME_DRIVER=/opt/project/tricon/chrome/chromedriver

# ---- Google Sheet IDs ----
MAPPING_SHEET_EXCEPTION=your_google_sheet_id
MAPPING_SHEET_INSURANCE=your_google_sheet_id
MAPPING_SHEET_ADULT_MEDICAID=your_google_sheet_id

# ---- Logging ----
LOG_FILE=/opt/project/tricon/log/ruleengine.log
APP_DEBUG_FOLDER=/opt/project/tricon/log/

# ---- Rule Engine Paths ----
RE_XSLT_PATH=/tmp/ruleengine/xml/
RE_XSLT_FILE=/opt/xslt/pdfformat.xslt
RE_XSLTOS_FILE=/opt/xslt/pdfformat_os.xslt
RE_XSLTORTHO_FILE=/opt/xslt/pdfformat_ortho.xslt
RE_XSLT_FILENEW=/opt/xslt/new_pdfformat.xslt
RE_XSLT_SEALANT=/opt/xslt/sealant.xslt

# ---- RCM Configuration ----
RCM_SERVER_DOMAIN=https://your-rcm-domain.com
RCM_RULEENGINE_BASE_URL=https://your-ruleengine-domain.com

# ---- Email Configuration (RCM) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-app-password
EMAIL_FROM=your-email@example.com

# ---- Google reCAPTCHA (RCM) ----
CAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ---- RCM Scheduler ----
SCHEDULER_STARTCRON=0 30 3 * * *
SCHEDULER_POSTING_STARTCRON=0 30 2 * * *

# ---- RCM Paths ----
RCM_XSLT_PATH=/opt/project/xml/
RCM_ATTACHMENT_PATH=/opt/project/attachments
RCM_EOBLINK_FOLDER=/opt/project/pdf

# ---- ES Data Replication ----
ES_REPLICATION_DB_URL=jdbc:mysql://your-rds-endpoint:3306/rule_engine?useSSL=false
ES_REPLICATION_DB_USERNAME=your_db_user
ES_REPLICATION_DB_PASSWORD=your_db_password

# ---- Domain Names ----
# RE_DOMAIN:      Single domain — used for SSL cert paths (/etc/letsencrypt/live/$RE_DOMAIN/).
#                 Must match the domain used with certbot.
RE_DOMAIN=your-ruleengine-domain.com
# RE_SERVER_NAME: Space-separated list of ALL domains nginx should respond to.
#                 Used as nginx server_name directive. Can include multiple domains.
#                 Example: caplineruleengine.com www.caplineruleengine.com production.ruleengine.caplineservices.in
RE_SERVER_NAME=your-ruleengine-domain.com

# RCM_DOMAIN:      Single domain for SSL cert paths.
RCM_DOMAIN=your-rcm-domain.com
# RCM_SERVER_NAME: Space-separated list of ALL domains nginx should respond to.
RCM_SERVER_NAME=your-rcm-domain.com

# ---- Docker Paths ----
CERTS_PATH=./certs

# ---- Nginx Proxy Config ----
# Which nginx config the reverse proxy uses. Options:
#   nginx-ssl.conf           - Both apps, HTTPS (default; needs SSL certs for both domains)
#   nginx-ssl-re-only.conf   - RuleEngine only, HTTPS
#   nginx-ssl-rcm-only.conf  - RCM only, HTTPS
#   nginx-nossl.conf         - Both apps, HTTP only (before certbot)
NGINX_CONF=nginx-ssl.conf

# ---- JVM Configuration (RuleEngine backend) ----
# Adjust -Xmx based on server RAM. For 4GB server with only RE: -Xmx2048m is good.
# For 4GB server with both RE+RCM: reduce to -Xmx1024m each.
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/opt/project/tricon/log/heapdump.hprof

# ---- CORS Allowed Origins (comma-separated) ----
# Add all frontend domains that should be allowed to call the backend API.
CORS_ALLOWED_ORIGINS=https://your-ruleengine-domain.com,https://your-rcm-domain.com

# ---- Proxy Timeout Configuration ----
PROXY_READ_TIMEOUT=1800s
PROXY_SEND_TIMEOUT=1800s

DOCKER_HUB_REPO=capline/rcm-and-ruleengine

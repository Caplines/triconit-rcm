{
	"info": {
		"_postman_id": "rcm-api-collection-001",
		"name": "RCM API",
		"description": "Rule Engine RCM Spring Boot Application - API Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8081" },
		{ "key": "token", "value": "" },
		{ "key": "c", "value": "" },
		{ "key": "r", "value": "" },
		{ "key": "t", "value": "1" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
	},
	"item": [
		{
			"name": "Auth",
			"auth": { "type": "noauth" },
			"item": [
				{
					"name": "Login (with captcha)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"\",\n  \"password\": \"\",\n  \"token\": \"\"\n}"
						},
						"url": "{{base_url}}/account/login"
					}
				},
				{
					"name": "Login (no captcha - testing)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"\",\n  \"password\": \"\"\n}"
						},
						"url": "{{base_url}}/account/l_abc",
						"event": [
							{
								"listen": "test",
								"script": {
									"exec": [
										"if (pm.response.code === 200) {",
										"    var json = pm.response.json();",
										"    if (json.data && json.data.token) {",
										"        pm.collectionVariables.set('token', json.data.token);",
										"    }",
										"}"
									],
									"type": "text/javascript"
								}
							}
						]
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"url": "{{base_url}}/refresh"
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"\"\n}"
						},
						"url": "{{base_url}}/forgotPassword"
					}
				},
				{
					"name": "Bootstrap Super Admin (no token)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"email\": \"\",\n  \"password\": \"\"\n}"
						},
						"url": "{{base_url}}/auth/bootstrap-super-admin"
					}
				}
			]
		},

						</td>
						<td  colspan="1">						
						  <span class="sub-heading"><xsl:value-of select="obtainMPN"/></span>
                            
                        </td>
                    </tr>
                    
                </tbody>
            </table>
			<xsl:if test="translate(basicInfo3, $smallcase, $uppercase) = 'GUARDIAN'">
			<table style="border: 1px solid #e0003f;">
			

						</td>
                        <td  colspan="4">						
						  <span class="sub-heading"><xsl:value-of select="sRemarks"/></span>
                            
                        </td>
						<td  class="withds">
                          <span class="main-heading-1">Updated Prim Ins in ES as BCBS Fedral:</span>
						</td>
						<td  colspan="2">						
						  <span class="sub-heading"><xsl:value-of select="esBcbs"/></span>
                            
                        </td>
						<td  class="withds">
